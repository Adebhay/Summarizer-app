{
  "manifest_version": 3,
  "name": "Mentiis.co - Smart Productivity Tracker",
  "version": "1.0.0",
  "description": "AI-powered productivity tracker that monitors your digital activity and delivers daily coaching summaries to help you work smarter, not harder.",
  "browser_specific_settings": {
    "gecko": {
      "id": "mentiis@mentiis.co",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "https://summarizer-app-ybx8.onrender.com/*"
  ],
  "background": {
    "scripts": [
      "../shared-scripts/browser-polyfill.js",
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mentiis.co"
  }
}